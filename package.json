{
  "name": "mastra-elastic-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hybrid Retrieval Patterns for AI Agents — a Mastra agent that retrieves over Elasticsearch using the native ElasticSearchVector store (vector search + filter); hybrid RRF + reranking shown at the Elasticsearch query layer.",
  "scripts": {
    "setup": "tsx src/scripts/setup-index.ts",
    "ingest": "tsx src/scripts/ingest.ts",
    "search": "tsx src/scripts/search.ts",
    "ask": "tsx src/scripts/ask.ts",
    "dev": "mastra dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@mastra/core": "^1.45.0",
    "@mastra/elasticsearch": "^1.3.0",
    "@mastra/libsql": "^1.14.0",
    "@mastra/memory": "^1.21.0",
    "dotenv": "^16.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "mastra": "^1.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
