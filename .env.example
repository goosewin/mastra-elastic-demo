# --- Elasticsearch -----------------------------------------------------------
# Elastic Cloud trial (recommended): https://cloud.elastic.co/registration
#   -> copy the endpoint URL, create an API key under Stack Management.
# Local (no API key needed): see README "Local Elasticsearch".
ELASTICSEARCH_URL=https://your-cluster.es.us-central1.gcp.cloud.es.io:443
ELASTICSEARCH_API_KEY=your_base64_api_key
ELASTICSEARCH_INDEX_NAME=scifi-movies

# --- OpenAI ------------------------------------------------------------------
# Used for query/document embeddings (text-embedding-3-small, 1536 dims)
# and for the agent's synthesis model (gpt-5-nano).
OPENAI_API_KEY=sk-...
